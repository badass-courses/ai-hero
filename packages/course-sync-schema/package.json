{
	"name": "@ai-hero/course-sync-schema",
	"version": "0.1.0",
	"description": "Effect v4 schema contract for syncing Course Video Manager course exports into Course Builder.",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "tsx test/schema.test.ts",
		"clean": "rm -rf dist *.tsbuildinfo"
	},
	"dependencies": {
		"effect": "4.0.0-beta.84"
	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=24"
	}
}
