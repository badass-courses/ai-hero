{
	"name": "ai-hero",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently --kill-others-on-fail \"npm:dev:*\"",
		"dev:next": "next dev --turbopack",
		"dev:inngest": "pnpx inngest-cli@latest dev --no-discovery -u http://localhost:3000/api/inngest",
		"dev:party": "pnpx partykit dev",
		"tunnel": "ngrok http --domain=neatly-diverse-goldfish.ngrok-free.app 3000",
		"email:preview": "email dev --dir ./src/emails",
		"build": "next build",
		"db:push": "dotenv drizzle-kit push",
		"db:studio": "dotenv drizzle-kit studio",
		"db:seed": "dotenv tsx ./src/db/seed.ts",
		"db:generate": "dotenv drizzle-kit generate",
		"db:migrate": "dotenv drizzle-kit migrate",
		"db:introspect": "dotenv drizzle-kit introspect",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"index-typesense": "dotenv tsx ./src/scripts/index-content.ts",
		"migrate-typesense": "dotenv tsx ./scripts/typesense-migrate.mts",
		"test": "vitest run -c vitest.config.ts",
		"test:e2e": "playwright test",
		"posts": "tsx scripts/posts-cli.ts",
		"artwork:replay": "tsx -r dotenv/config scripts/artwork-replay.ts",
		"discord:backfill-legend": "tsx scripts/backfill-discord-legend-role.mts",
		"subscriber-marketing:dry-run": "tsx src/scripts/subscriber-marketing-dry-run.ts",
		"subscriber-marketing:operator": "tsx -r dotenv/config src/scripts/subscriber-marketing-operator.ts",
		"ads:operator": "tsx -r dotenv/config src/scripts/ads-operator.ts",
		"billing-admins:backfill": "tsx -r dotenv/config src/scripts/billing-admins-backfill.ts",
		"billing-admins:synthetic-proof": "tsx -r dotenv/config src/scripts/billing-admins-synthetic-proof.ts",
		"cohort-004:shell-sync": "bun src/scripts/cohort-004-shell-sync.ts",
		"cohort-004:video-upload-sync": "tsx -r dotenv/config src/scripts/cohort-004-video-upload-sync.ts",
		"cohort-004:body-content-sync": "tsx -r dotenv/config src/scripts/cohort-004-body-content-sync.ts",
		"cohort-004:backfill-purchases": "tsx -r dotenv/config scripts/backfill-cohort-004-purchases.mts",
		"cohort-004:backfill-status": "tsx -r dotenv/config scripts/cohort-004-backfill-status.mts",
		"cohort-004:repair-entitlements": "tsx -r dotenv/config scripts/repair-cohort-004-entitlements.mts"
	},
